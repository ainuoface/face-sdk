# Track only SDK distribution files needed by JitPack and CocoaPods.
/*

!/.gitignore
!/README.md
!/AinuoFaceSDK.podspec
!/build.gradle.kts
!/settings.gradle.kts
!/jitpack.yml

!/maven/
!/maven/**

!/ios/
!/ios/Frameworks/
!/ios/Frameworks/**

!/android/
!/android/gradlew
!/android/gradlew.bat
!/android/gradle/
!/android/gradle/wrapper/
!/android/gradle/wrapper/**

# Generated demo projects stay local only.
/android/**
!/android/gradlew
!/android/gradlew.bat
!/android/gradle/
!/android/gradle/wrapper/
!/android/gradle/wrapper/**
/ios/**
!/ios/Frameworks/
!/ios/Frameworks/**

# Local build and IDE state.
**/.DS_Store
/.gradle/
/build/
/android/.gradle/
/android/.kotlin/
/android/**/build/
/android/local.properties
/android/captures/
/android/*.iml
/android/**/.idea/
/.idea/
*.iml
/ios/build/
/ios/DerivedData/
/ios/**/*.xcodeproj/xcuserdata/
/ios/**/*.xcworkspace/xcuserdata/
/ios/**/*.xcuserstate
/ios/**/*.xcscmblueprint
/ios/.build/
/ios/.swiftpm/
/ios/Pods/
*.log
*.tmp
*.swp
